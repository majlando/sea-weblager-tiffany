<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import dk.easv.weblager.gui.control.SvgIcon?>

<VBox prefWidth="1000" prefHeight="640" minWidth="880" minHeight="540"
      styleClass="root-pane"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="dk.easv.weblager.gui.controller.AdminDashboardController">

    <stylesheets>
        <URL value="@styles.css"/>
    </stylesheets>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="app-header">
        <padding><Insets top="12" right="18" bottom="12" left="18"/></padding>

        <Pane fx:id="logoContainer" maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="28"/>
        <Label styleClass="h2" text="Admin Dashboard"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="welcomeLabel" styleClass="body-muted"/>
        <Button onAction="#onLogout" styleClass="secondary-button" text="Logout"
                contentDisplay="LEFT" graphicTextGap="6">
            <graphic><SvgIcon iconLiteral="sign-out" iconSize="14"/></graphic>
        </Button>
    </HBox>

    <!-- Body -->
    <VBox spacing="12" VBox.vgrow="ALWAYS">
        <padding><Insets top="18" right="24" bottom="18" left="24"/></padding>

        <!-- Toolbar: search, role filter, action buttons -->
        <HBox alignment="CENTER_LEFT" spacing="12">
            <HBox alignment="CENTER_LEFT" spacing="9" styleClass="input-wrapper"
                  HBox.hgrow="ALWAYS" minWidth="180">
                <SvgIcon iconLiteral="search" iconSize="14" styleClass="input-icon"/>
                <TextField fx:id="searchField" promptText="Search username…"
                           styleClass="input-inner" HBox.hgrow="ALWAYS"/>
            </HBox>

            <ComboBox fx:id="roleFilter" prefWidth="140"/>

            <Button fx:id="createButton" onAction="#onCreate" text="Create"
                    styleClass="primary-button" contentDisplay="LEFT" graphicTextGap="6">
                <graphic><SvgIcon iconLiteral="plus" iconSize="14"/></graphic>
            </Button>
            <Button fx:id="editButton" onAction="#onEdit" text="Edit"
                    styleClass="secondary-button" contentDisplay="LEFT" graphicTextGap="6">
                <graphic><SvgIcon iconLiteral="pencil" iconSize="14"/></graphic>
            </Button>
            <Button fx:id="deleteButton" onAction="#onDelete" text="Delete"
                    styleClass="destructive-button" contentDisplay="LEFT" graphicTextGap="6">
                <graphic><SvgIcon iconLiteral="trash" iconSize="14"/></graphic>
            </Button>
        </HBox>

        <!-- Feedback (success/error) -->
        <Label fx:id="feedbackLabel" minHeight="15" wrapText="true"/>

        <!-- User table -->
        <TableView fx:id="userTable" VBox.vgrow="ALWAYS">
            <placeholder>
                <Label styleClass="body-muted" text="No users match your filter."/>
            </placeholder>
            <columns>
                <TableColumn fx:id="colUsername" prefWidth="220" text="Username"/>
                <TableColumn fx:id="colRole"     prefWidth="120" text="Role"/>
                <TableColumn fx:id="colCreated"  prefWidth="180" text="Created"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY_ALL_COLUMNS"/>
            </columnResizePolicy>
        </TableView>
    </VBox>
</VBox>
