<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import dk.easv.weblager.gui.control.SvgIcon?>

<!-- rootPane sits in the center of the window; the inner VBox is the login card. -->
<StackPane styleClass="root-pane"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="dk.easv.weblager.gui.LoginController">

    <VBox maxWidth="360" maxHeight="-Infinity" spacing="18" styleClass="login-card">
        <padding><Insets top="28" right="28" bottom="28" left="28"/></padding>

        <!-- Logo -->
        <Pane fx:id="logoContainer" maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="50"/>

        <Label styleClass="body-muted" text="Sign in to your account"/>

        <!-- Username -->
        <VBox spacing="6">
            <Label styleClass="field-label" text="Username"/>
            <HBox alignment="CENTER_LEFT" spacing="8" styleClass="input-wrapper">
                <SvgIcon iconLiteral="user" iconSize="14" styleClass="input-icon"/>
                <TextField fx:id="usernameField" promptText="Username"
                           styleClass="input-inner" HBox.hgrow="ALWAYS"/>
            </HBox>
        </VBox>

        <!-- Password -->
        <VBox spacing="6">
            <Label styleClass="field-label" text="Password"/>
            <HBox alignment="CENTER_LEFT" spacing="8" styleClass="input-wrapper">
                <SvgIcon iconLiteral="lock" iconSize="14" styleClass="input-icon"/>
                <PasswordField fx:id="passwordField" promptText="Password"
                               styleClass="input-inner" HBox.hgrow="ALWAYS"/>
            </HBox>
        </VBox>

        <Label fx:id="errorLabel" styleClass="error-label" wrapText="true"/>

        <!-- Login button with sign-in icon -->
        <Button defaultButton="true" maxWidth="Infinity" onAction="#onLogin"
                styleClass="primary-button" text="Login" contentDisplay="LEFT" graphicTextGap="8">
            <graphic>
                <SvgIcon iconLiteral="sign-in" iconSize="14"/>
            </graphic>
        </Button>
    </VBox>
</StackPane>
