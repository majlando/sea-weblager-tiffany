<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import dk.easv.weblager.gui.control.SvgIcon?>

<VBox prefWidth="380" spacing="15" styleClass="root-pane"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="dk.easv.weblager.gui.controller.UserDialogController">

    <stylesheets>
        <URL value="@styles.css"/>
    </stylesheets>

    <padding><Insets top="21" right="21" bottom="21" left="21"/></padding>

    <Label fx:id="titleLabel" styleClass="h2" text="Create User"/>

    <!-- Username -->
    <VBox spacing="9">
        <Label styleClass="field-label" text="Username"/>
        <HBox alignment="CENTER_LEFT" spacing="9" styleClass="input-wrapper">
            <SvgIcon iconLiteral="user" iconSize="14" styleClass="input-icon"/>
            <TextField fx:id="usernameField" promptText="Username"
                       styleClass="input-inner" HBox.hgrow="ALWAYS"/>
        </HBox>
    </VBox>

    <!-- Password -->
    <VBox spacing="9">
        <Label styleClass="field-label" text="Password"/>
        <HBox alignment="CENTER_LEFT" spacing="9" styleClass="input-wrapper">
            <SvgIcon iconLiteral="lock" iconSize="14" styleClass="input-icon"/>
            <PasswordField fx:id="passwordField" promptText="Password"
                           styleClass="input-inner" HBox.hgrow="ALWAYS"/>
        </HBox>
    </VBox>

    <!-- Role -->
    <VBox spacing="9">
        <Label styleClass="field-label" text="Role"/>
        <ComboBox fx:id="roleCombo" maxWidth="Infinity"/>
    </VBox>

    <Label fx:id="errorLabel" styleClass="error-label" minHeight="15" wrapText="true"/>

    <!-- Actions -->
    <HBox alignment="CENTER_RIGHT" spacing="6">
        <Region HBox.hgrow="ALWAYS"/>
        <Button cancelButton="true" onAction="#onCancel" text="Cancel"
                styleClass="outline-button" contentDisplay="LEFT" graphicTextGap="6">
            <graphic><SvgIcon iconLiteral="times" iconSize="14"/></graphic>
        </Button>
        <Button fx:id="saveButton" defaultButton="true" onAction="#onSave" text="Create"
                styleClass="primary-button" contentDisplay="LEFT" graphicTextGap="6">
            <graphic><SvgIcon iconLiteral="check" iconSize="14"/></graphic>
        </Button>
    </HBox>
</VBox>
